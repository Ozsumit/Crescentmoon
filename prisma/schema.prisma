generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Feedback {
  id        String   @id @default(cuid())
  type      String
  rating    Int?
  message   String
  email     String?
  createdAt DateTime @default(now())
}

model PageView {
  id        String   @id @default(cuid())
  path      String
  visitorId String
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([path])
}

/// The underlying table does not contain a valid unique identifier and can therefore currently not be handled by Prisma Client.
model VideoSource {
  id          String   @id
  active      Boolean
  createdAt   DateTime
  description String?
  download    Boolean
  features    Json
  icon        String?
  name        String
  params      String?
  paramStyle  String?
  parseUrl    Boolean
  priority    Int
  type        String
  updatedAt   DateTime @updatedAt
  url         String
}